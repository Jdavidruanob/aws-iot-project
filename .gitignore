lambda/s3_to_postgres/*.egg-info
lambda/s3_to_postgres/pg8000/
lambda/s3_to_postgres/scramp/
lambda/s3_to_postgres/*.dist-info/
lambda/s3_to_postgres/asn1crypto/
lambda/s3_to_postgres/dateutil/
lambda/s3_to_postgres/six.py

# Python
__pycache__/
*.pyc
*.pyo
.env

# Zips de Lambda generados
/tmp/*.zip
