# Certificados generados por Terraform (secretos)
edge_gateway/certs/
edge_gateway/mosquitto.conf

# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
